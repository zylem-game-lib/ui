{
  "name": "@zylem/ui",
  "version": "0.1.0",
  "description": "Design tokens, global styles, and Solid components for Zylem, built with vanilla-extract",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zylem-game-lib/ui.git"
  },
  "homepage": "https://github.com/zylem-game-lib/ui#readme",
  "bugs": {
    "url": "https://github.com/zylem-game-lib/ui/issues"
  },
  "keywords": [
    "zylem",
    "design-tokens",
    "vanilla-extract",
    "solid-js",
    "ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "import": "./src/components/index.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "NODE_ENV=production tsup",
    "dev": "tsup --watch",
    "showcase": "vite --host",
    "lint": "biome check ."
  },
  "peerDependencies": {
    "solid-js": "^1.9.9"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "@kobalte/core": "^0.13.11",
    "@vanilla-extract/esbuild-plugin": "^2.3.22",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "lucide-solid": "^0.511.0",
    "solid-js": "^1.9.9",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vite": "7.0.4",
    "vite-plugin-solid": "^2.11.8"
  },
  "dependencies": {
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/sprinkles": "^1.6.5"
  }
}